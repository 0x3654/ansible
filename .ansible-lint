---
# Ansible Lint Configuration
exclude_paths:
  # files/ в ролях — application-код субмодулей (compose, nginx, GitHub Actions), не Ansible
  - roles/gisp/files/
  - roles/homelab/files/
  - roles/subnginx3xui/files/
  - roles/untilwall/files/
  - roles/vpnserver/files/
  # Шаблон роли (содержит плейсхолдеры вместо реальных значений)
  - roles/.template/
  # Скрытые файлы
  - .cache/
  - .git/
skip_list:
  - collection  # уже было
  # Исключаем только то, что реально нельзя исправить:
  - command-instead-of-shell  # для firewall.yml (iptables) и docker exec
  - role-name[path]  # для deploy.yml (динамический импорт ролей по пути)
