---
# Manage role secrets
# Copy this file to secrets.yml and fill in your values

# Beszel config
manage_beszel_port: "45876"
manage_beszel_public_key: "ssh-ed25519 YOUR_KEY_HERE"
manage_beszel_token: "YOUR_TOKEN_HERE"

# Watchtower config (optional)
manage_watchtower_tg_wt_bot_token: "YOUR_BOT_TOKEN_HERE"
manage_watchtower_tg_wt_chat_id: "YOUR_CHAT_ID_HERE"
manage_watchtower_timezone: "Asia/Tbilisi"

# Tailscale (set per host, reusable key from https://login.tailscale.com/admin/settings/keys)
manage_tailscale_enabled: false
manage_tailscale_authkey: "tskey-auth-YOUR_KEY_HERE"
