---
# Semaphore role secrets
# Copy this file to secrets.yml and fill in your values

semaphore_domain_name: "semaphore.example.com"
semaphore_port: "3210"
semaphore_container_port: "3000"
semaphore_web_root: "https://{{ semaphore_domain_name }}"
semaphore_admin: "admin"
semaphore_admin_name: "Admin"
semaphore_admin_email: "admin@localhost"
semaphore_cert_path: "/server/certbot"
semaphore_container_uid: "1001"

semaphore_admin_password: "changeme"
semaphore_access_key_encryption: "YOUR_KEY_HERE"

# Telegram notifications for SSL certificate renewals
semaphore_telegram_bot_token: "YOUR_BOT_TOKEN_HERE"
semaphore_telegram_chat_id: "YOUR_CHAT_ID_HERE"

# Tailscale (reusable auth key from https://login.tailscale.com/admin/settings/keys)
semaphore_tailscale_authkey: "tskey-auth-YOUR_KEY_HERE"
