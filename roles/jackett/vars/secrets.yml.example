---
# Jackett role secrets
# Copy this file to secrets.yml and fill in your values

# Domain
jackett_domain_name: "jackett.example.com"

# Admin password hash (SHA256 of your password), empty string = no password
# Generate: echo -n "yourpassword" | sha256sum | awk '{print $1}'
jackett_admin_password_hash: ""

# API key — random string used by Lampa/Sonarr/Radarr to access Jackett
# Generate: openssl rand -hex 16
jackett_api_key: "YOUR_API_KEY_HERE"

# Rutracker credentials
jackett_rutracker_username: "YOUR_USERNAME"
jackett_rutracker_password: "YOUR_PASSWORD"

# NNM-Club credentials
jackett_nnmclub_username: "YOUR_USERNAME"
jackett_nnmclub_password: "YOUR_PASSWORD"

# Kinozal credentials
jackett_kinozal_username: "YOUR_USERNAME"
jackett_kinozal_password: "YOUR_PASSWORD"

# AniDUB credentials
jackett_anidub_username: "YOUR_USERNAME"
jackett_anidub_password: "YOUR_PASSWORD"

# UnionGang credentials
jackett_uniongang_username: "YOUR_USERNAME"
jackett_uniongang_password: "YOUR_PASSWORD"

# Public trackers (no credentials needed): rutor, animelayer, anilibria
